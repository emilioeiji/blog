&lt;span class="kt"&gt;int&lt;/span&gt; &lt;span class="n"&gt;pinoAnalogico&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="mi"&gt;3&lt;/span&gt;&lt;span class="p"&gt;;&lt;/span&gt;
&lt;span class="kt"&gt;int&lt;/span&gt; &lt;span class="n"&gt;pinoAnalogico2&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="mi"&gt;0 …&lt;/span&gt;&lt;/pre&gt;&lt;/div&gt;</description><dc:creator xmlns:dc="http://purl.org/dc/elements/1.1/">Emilio</dc:creator><pubDate>Sun, 23 Sep 2012 23:25:00 -0300</pubDate><guid isPermaLink="false">tag:blog.emilioeiji.com.br,2012-09-23:/arduino-uno-sensor-ldr-e-lm35-apresentando-informacoes-no-display-16x2.html</guid><category>ardunio</category><category>sensor</category><category>lm35</category><category>display</category><category>ldr</category></item></channel></rss>